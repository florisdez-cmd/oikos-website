---
layout: base.njk
title: Nieuws – Oikos Bouwend Bureau
permalink: /nieuws/
---
<main class="pt-32 pb-28 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="section-tag">Alle updates</span>
      <h1 class="text-4xl font-extrabold text-oikos-dark">Nieuws &amp; projecten</h1>
      <p class="text-oikos-gray mt-4 text-lg max-w-xl mx-auto">Lees hier meer over onze projecten, materialen en inzichten rondom duurzame renovatie.</p>
    </div>

    {%- set allePosts = collections.post | reverse -%}
    {% if allePosts.length > 0 %}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {% for post in allePosts %}
      <article class="card-hover group fade-up d{{ (loop.index0 % 3) + 1 }} rounded-2xl overflow-hidden border border-gray-100">
        <a href="{{ post.url }}" class="block">
          <div class="overflow-hidden aspect-video bg-oikos-green-light">
            {% if post.data.image %}
            <img src="{{ post.data.image }}" alt="{{ post.data.title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            {% else %}
            <div class="w-full h-full flex items-center justify-center">
              <img src="/assets/logo-hart.png" alt="Oikos" class="h-16 opacity-30" />
            </div>
            {% endif %}
          </div>
          <div class="h-0.5 bg-oikos-green origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
          <div class="p-5">
            <p class="text-oikos-gray text-xs mb-3">{{ post.date | dutchDate }}</p>
            <h2 class="text-lg font-bold text-oikos-dark mb-2 group-hover:text-oikos-green transition-colors leading-snug">{{ post.data.title }}</h2>
            <p class="text-oikos-gray text-sm leading-relaxed line-clamp-2">{{ post.data.excerpt or post.templateContent | striptags | truncate(120) }}</p>
            <p class="text-oikos-green text-sm font-semibold mt-4 flex items-center gap-1 opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
              Lees meer
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </p>
          </div>
        </a>
      </article>
      {% endfor %}
    </div>
    {% else %}
    <p class="text-oikos-gray text-center py-16">Er zijn nog geen berichten. Voeg ze toe via <a href="/admin/" class="text-oikos-green underline">het admin-panel</a>.</p>
    {% endif %}
  </div>
</main>
