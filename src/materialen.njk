---
layout: base.njk
title: Materialen – Oikos Bouwend Bureau
description: Een overzicht van de biobased isolatiematerialen waarmee Oikos werkt, inclusief technische specificaties.
permalink: /materialen/
---

<main class="pt-20 bg-white">

  <!-- Hero -->
  <section class="bg-oikos-dark pt-16 pb-14">
    <div class="max-w-5xl mx-auto px-6">
      <span class="text-oikos-green text-xs font-bold tracking-[0.2em] uppercase mb-3 block">Kennisbank</span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white leading-tight mb-4 max-w-2xl">Materialen</h1>
      <p class="text-white/60 text-lg max-w-2xl leading-relaxed">
        Oikos werkt met biobased isolatiematerialen. Hier vind je voor elk materiaal de technische eigenschappen, de toepassingen en de bouwkundige context. Omdat die informatie niet altijd makkelijk te vinden is.
      </p>
    </div>
  </section>

  <!-- Split panel -->
  <section class="max-w-5xl mx-auto px-6 py-12 md:py-16">
    <div class="flex flex-col md:flex-row gap-10 md:gap-14">

      <!-- Linker materiaalnav -->
      <div class="md:w-52 flex-shrink-0">
        <p class="text-[10px] font-bold tracking-widest text-oikos-gray uppercase mb-3">Materialen</p>
        <ul class="flex flex-row overflow-x-auto gap-1 pb-2 md:flex-col md:space-y-0.5 md:overflow-x-visible md:pb-0" id="material-list">
          {% for mat in materialen.items %}
          <li><button data-mat="{{ mat.id }}" class="mat-btn{% if loop.first %} active{% endif %} w-full text-left">{{ mat.naam }}</button></li>
          {% endfor %}
        </ul>
      </div>

      <!-- Rechter inhoud -->
      <div class="flex-1 min-w-0">

        {% for mat in materialen.items %}
        <div id="panel-{{ mat.id }}" class="mat-panel{% if not loop.first %} hidden{% endif %}">
          <p class="text-oikos-green text-xs font-bold tracking-widest uppercase mb-1">{{ mat.categorie }}</p>
          <h2 class="text-3xl font-extrabold text-oikos-dark mb-2">{{ mat.naam }}</h2>
          <p class="text-oikos-gray text-sm mb-6 leading-relaxed max-w-xl">{{ mat.beschrijving }}</p>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
            {% for spec in mat.specs %}
            <div class="spec-card">
              <span class="spec-label">{{ spec.label }}</span>
              <span class="spec-val">{{ spec.waarde }}</span>
              {% if spec.eenheid %}<span class="spec-unit">{{ spec.eenheid }}</span>{% endif %}
            </div>
            {% endfor %}
          </div>

          <div class="mb-8">
            <p class="text-[10px] font-bold tracking-widest text-oikos-gray uppercase mb-3">Toepassingen</p>
            <div class="flex flex-wrap gap-2">
              {% for toepassing in mat.toepassingen %}
              <span class="tag">{{ toepassing }}</span>
              {% endfor %}
            </div>
          </div>

          <div class="mb-4">
            <p class="text-[10px] font-bold tracking-widest text-oikos-gray uppercase mb-3">Eigenschappen</p>
            <ul class="space-y-2 text-sm text-oikos-gray">
              {% for eigenschap in mat.eigenschappen %}
              <li class="flex gap-2"><span class="text-oikos-green font-bold flex-shrink-0">—</span> {{ eigenschap }}</li>
              {% endfor %}
            </ul>
          </div>

          <div class="tekeningen-section mt-8 border-t border-gray-100 pt-6">
            <button class="tekeningen-toggle flex items-center gap-2 text-sm text-oikos-gray hover:text-oikos-dark transition-colors">
              <svg class="h-4 w-4 tekeningen-arrow transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              <span class="font-semibold">Bouwtechnische tekeningen</span>
            </button>
            <div class="tekeningen-panel hidden mt-4">
              {% if mat.tekeningen and mat.tekeningen.length > 0 %}
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  {% for tekening in mat.tekeningen %}
                  <img src="{{ tekening }}" alt="Bouwtechnische tekening {{ mat.naam }}" class="rounded-xl border border-gray-200 w-full">
                  {% endfor %}
                </div>
              {% else %}
                <p class="text-oikos-gray text-sm leading-relaxed">Bouwtechnische tekeningen worden hier toegevoegd zodra ze beschikbaar zijn. Neem contact op voor specifieke detailtekeningen.</p>
              {% endif %}
            </div>
          </div>
        </div>
        {% endfor %}

      </div>
    </div>
  </section>


</main>

<style>
  .mat-btn {
    padding: 10px 14px;
    border-radius: 10px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #6B6B6B;
    background: transparent;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    border-left: 3px solid transparent;
    text-align: left;
    white-space: nowrap;
  }
  .mat-btn:hover { background: #EFF7DC; color: #3C3C3C; }
  .mat-btn.active { background: #EFF7DC; color: #3C3C3C; border-left-color: #8DC63F; }

  .spec-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px;
    border-radius: 12px;
    background: #F8FAF4;
    border: 1px solid #E8F0D8;
  }
  .spec-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #6B6B6B; }
  .spec-val   { font-size: 1.25rem; font-weight: 800; color: #3C3C3C; line-height: 1.2; }
  .spec-unit  { font-size: 0.7rem; color: #6B6B6B; font-weight: 500; }

  .tag {
    background: #F0F0F0;
    color: #3C3C3C;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 99px;
  }
</style>

<script>
  function showMat(id) {
    document.querySelectorAll('.mat-btn').forEach(function(b) { b.classList.remove('active'); });
    document.querySelectorAll('.mat-panel').forEach(function(p) { p.classList.add('hidden'); });
    var btn = document.querySelector('[data-mat="' + id + '"]');
    var panel = document.getElementById('panel-' + id);
    if (btn) btn.classList.add('active');
    if (panel) panel.classList.remove('hidden');
  }

  // URL-param: ?m=schapenwol
  var urlMat = new URLSearchParams(window.location.search).get('m');
  if (urlMat) showMat(urlMat);

  document.querySelectorAll('.mat-btn').forEach(function(btn) {
    btn.addEventListener('click', function() { showMat(btn.dataset.mat); });
  });

  // Bouwtechnische tekeningen uitklappen
  document.querySelectorAll('.tekeningen-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var panel = btn.nextElementSibling;
      var arrow = btn.querySelector('.tekeningen-arrow');
      panel.classList.toggle('hidden');
      arrow.style.transform = panel.classList.contains('hidden') ? '' : 'rotate(90deg)';
    });
  });
</script>
