      <a href="/">
        <img src="/assets/logo-voorzijde.png" alt="Oikos Bouwend Bureau" class="h-16 w-auto" />
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="/#over-ons"  class="text-gray-900 hover:text-oikos-green transition-colors text-sm font-semibold">Over ons</a>
        <a href="/#projecten" class="text-gray-900 hover:text-oikos-green transition-colors text-sm font-semibold">Projecten & nieuws</a>
        <a href="/#materiaal" class="text-gray-900 hover:text-oikos-green transition-colors text-sm font-semibold">Materiaal</a>
        <a href="/#diensten"  class="text-gray-900 hover:text-oikos-green transition-colors text-sm font-semibold">Diensten</a>
        <a href="/#contact"   class="bg-oikos-green hover:bg-oikos-green-dark text-white px-5 py-2.5 rounded-full text-sm font-semibold transition-colors">Contact</a>
      </div>
      <button id="mobile-menu-btn" class="md:hidden text-oikos-dark" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
    <div id="mobile-menu" class="md:hidden hidden bg-white border-t border-gray-100 px-6 py-4 flex flex-col gap-4 text-sm font-semibold">
      <a href="/#over-ons"  class="text-gray-900 hover:text-oikos-green">Over ons</a>
      <a href="/#projecten" class="text-gray-900 hover:text-oikos-green">Projecten & nieuws</a>
      <a href="/#materiaal" class="text-gray-900 hover:text-oikos-green">Materiaal</a>
      <a href="/#diensten"  class="text-gray-900 hover:text-oikos-green">Diensten</a>
      <a href="/#contact"   class="bg-oikos-green text-white px-5 py-2.5 rounded-full text-center font-semibold">Contact</a>
    </div>
  </nav>

  <!-- ===== PAGINA-INHOUD ===== -->
  {{ content | safe }}

  <!-- ===== CTA BANNER ===== -->
  <section class="bg-oikos-green py-20">
    <div class="max-w-4xl mx-auto px-6 text-center fade-up">
      <h2 class="text-4xl font-extrabold text-white mb-5">Jouw woning klaar voor 2050?</h2>
      <p class="text-white/85 text-xl mb-10 leading-relaxed max-w-2xl mx-auto">
        Oikos werkt samen met enthousiaste woningeigenaren aan een duurzame toekomst.
        Neem contact op voor een vrijblijvend gesprek.
      </p>
      <a href="/#contact" class="bg-white text-oikos-green hover:bg-gray-100 px-10 py-4 rounded-full font-bold text-base transition-colors inline-block shadow-lg">
        Neem contact op
      </a>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
