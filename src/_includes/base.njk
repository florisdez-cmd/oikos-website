<!DOCTYPE html>
<html lang="nl" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title or "Oikos – Bouwend Bureau | Den Haag" }}</title>
  <meta name="description" content="{{ description or 'Duurzame renovatie met hennepvezels. Wij maken woningen klaar voor 2050.' }}" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'oikos-green':       '#8DC63F',
            'oikos-green-dark':  '#72A832',
            'oikos-green-light': '#EFF7DC',
            'oikos-dark':        '#3C3C3C',
            'oikos-gray':        '#6B6B6B',
          },
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
          },
        },
      },
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    html { scroll-behavior: smooth; }
    .hero-overlay {
      background: linear-gradient(180deg, rgba(30,30,30,0.45) 0%, rgba(30,30,30,0.60) 60%, rgba(30,30,30,0.80) 100%);
    }
    .hero-slides { position: absolute; inset: 0; }
    .hero-slide {
      position: absolute; inset: 0;
      width: 100%; height: 100%; object-fit: cover;
      opacity: 0;
      transition: opacity 1.5s ease-in-out;
    }
    .hero-slide.active { opacity: 1; }
    /* Bronverwijzing inline uitklapper */
    .bron-marker {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      border: 1.5px solid #8DC63F;
      color: #8DC63F;
      font-size: 0.6rem;
      font-weight: 700;
      vertical-align: middle;
      cursor: pointer;
      margin: 0 2px;
      transition: background 0.2s, color 0.2s;
      user-select: none;
      line-height: 1;
    }
    .bron-marker.open,
    .bron-marker:hover {
      background: #8DC63F;
      color: white;
    }
    .bron-card-wrap {
      display: block;
      overflow: hidden;
      max-height: 0;
      transition: max-height 0.35s ease, opacity 0.3s ease;
      opacity: 0;
    }
    .bron-card-wrap.open {
      max-height: 200px;
      opacity: 1;
    }
    .bron-card {
      display: block;
      background: #f8f9fa;
      border-radius: 12px;
      padding: 14px 18px;
      margin: 10px 0 6px 0;
      font-size: 0.875rem;
      color: #6B6B6B;
      line-height: 1.6;
      border: 1px solid #e8e8e8;
    }
    .bron-card a {
      color: #8DC63F;
      text-decoration: underline;
    }
    .typewriter-cursor {
      display: inline-block;
      color: #8DC63F;
      font-weight: 300;
      animation: blink 1s step-end infinite;
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
    .card-hover { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .card-hover:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(0,0,0,0.10); }
    .section-tag {
      display: block;
      color: #8DC63F;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }

    /* ── Hero entrance ── */
    @keyframes heroIn {
      from { opacity: 0; transform: translateY(22px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero-label { animation: heroIn 0.65s ease both; }
    .hero-h1    { animation: heroIn 0.70s ease 0.13s both; }
    .hero-p     { animation: heroIn 0.70s ease 0.26s both; }
    .hero-cta   { animation: heroIn 0.70s ease 0.38s both; }
    .hero-right { animation: heroIn 0.90s ease 0.22s both; }

    /* ── Scroll fade-up ── */
    .fade-up {
      opacity: 0;
      transform: translateY(26px);
      transition: opacity 0.65s ease, transform 0.65s ease;
    }
    .fade-up.in-view { opacity: 1; transform: translateY(0); }
    .fade-up.d1 { transition-delay: 0.10s; }
    .fade-up.d2 { transition-delay: 0.20s; }
    .fade-up.d3 { transition-delay: 0.30s; }
    .fade-up.d4 { transition-delay: 0.40s; }

    /* ── Slide from right ── */
    .fade-right {
      opacity: 0;
      transform: translateX(24px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .fade-right.in-view { opacity: 1; transform: translateX(0); }
    .fade-right.d1 { transition-delay: 0.10s; }
    .fade-right.d2 { transition-delay: 0.22s; }
    .fade-right.d3 { transition-delay: 0.34s; }
    .fade-right.d4 { transition-delay: 0.46s; }

    /* ── Line draw (eenmalig, scroll-triggered) ── */
    .line-draw {
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 1.6s cubic-bezier(0.4, 0, 0.2, 1) 0.2s;
    }
    .line-draw.in-view { transform: scaleX(1); }

    /* ── Line loop (stap voor stap, continu) ── */
    @keyframes lineLoop {
      0%      { transform: scaleX(0);     }  /* start bij stap 1    */
      14%     { transform: scaleX(0.333); }  /* aankomst stap 2     */
      24%     { transform: scaleX(0.333); }  /* pauze bij stap 2    */
      38%     { transform: scaleX(0.667); }  /* aankomst stap 3     */
      48%     { transform: scaleX(0.667); }  /* pauze bij stap 3    */
      62%     { transform: scaleX(1);     }  /* aankomst stap 4     */
      75%     { transform: scaleX(1);     }  /* even vasthouden      */
      75.5%   { transform: scaleX(0);     }  /* snap terug naar 1   */
      100%    { transform: scaleX(0);     }  /* pauze voor herhaling */
    }
    .line-loop {
      transform-origin: left;
      animation: lineLoop 7s ease-in-out infinite;
    }

    /* ── Step circle pop ── */
    .circle-pop { transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.5s ease; }
    .fade-up .circle-pop { opacity: 0; transform: scale(0.5); }
    .fade-up.in-view .circle-pop { opacity: 1; transform: scale(1); }
    .fade-up.d1 .circle-pop { transition-delay: 0.22s; }
    .fade-up.d2 .circle-pop { transition-delay: 0.35s; }
    .fade-up.d3 .circle-pop { transition-delay: 0.48s; }
    .fade-up.d4 .circle-pop { transition-delay: 0.61s; }


    /* ── Step card slide-in ── */
    .step-card { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .step-card:hover { transform: translateY(-6px); box-shadow: 0 20px 48px rgba(141,198,63,0.18); }
  </style>
</head>
<body class="bg-white text-oikos-dark font-sans antialiased">

  <!-- ===== NAVIGATIE ===== -->
  <nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
    <div class="max-w-6xl mx-auto px-6 py-1 md:py-4 flex items-center justify-between">
      <a href="/" class="relative block h-10 w-10">
        <!-- Wit+groen logo (zichtbaar op hero) -->
        <img id="logo-light" src="/assets/img/logo-hart-wit-groen.png" alt="Oikos Bouwend Bureau" class="h-10 w-auto absolute top-0 left-0 transition-opacity duration-500" />
        <!-- Donker+groen logo (zichtbaar op witte achtergrond) -->
        <img id="logo-dark"  src="/assets/img/logo-hart-transparant.png" alt="Oikos Bouwend Bureau" class="h-10 w-auto absolute top-0 left-0 transition-opacity duration-500 opacity-0" />
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="/"           class="nav-link transition-colors duration-300 text-sm font-semibold hover:text-oikos-green">Home</a>
        <a href="/#projecten" class="nav-link transition-colors duration-300 text-sm font-semibold hover:text-oikos-green">Projecten & nieuws</a>
        <a href="/materialen/" class="nav-link transition-colors duration-300 text-sm font-semibold hover:text-oikos-green">Materialen</a>
        <a href="/#over-ons"  class="nav-link transition-colors duration-300 text-sm font-semibold hover:text-oikos-green">Over ons</a>
        <a href="/#contact"   class="bg-oikos-green hover:bg-oikos-green-dark text-white px-5 py-2.5 rounded-full text-sm font-semibold transition-colors">Contact</a>
      </div>
      <button id="mobile-menu-btn" class="md:hidden transition-colors duration-300" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
    <div id="mobile-menu" class="md:hidden hidden bg-white border-t border-gray-100 px-6 py-4 flex flex-col gap-4 text-sm font-semibold">
      <a href="/"           class="text-gray-900 hover:text-oikos-green">Home</a>
      <a href="/#projecten" class="text-gray-900 hover:text-oikos-green">Projecten & nieuws</a>
      <a href="/materialen/" class="text-gray-900 hover:text-oikos-green">Materialen</a>
      <a href="/#over-ons"  class="text-gray-900 hover:text-oikos-green">Over ons</a>
      <a href="/#contact"   class="bg-oikos-green text-white px-5 py-2.5 rounded-full text-center font-semibold">Contact</a>
    </div>
  </nav>

  <!-- ===== PAGINA-INHOUD ===== -->
  {{ content | safe }}

  {% if page.url != '/' %}
  <!-- ===== CTA BANNER ===== -->
  <section class="bg-oikos-green py-14 md:py-20">
    <div class="max-w-4xl mx-auto px-6 text-center fade-up">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-5">Jouw woning klaar voor 2050?</h2>
      <p class="text-white/85 text-base md:text-xl mb-7 md:mb-10 leading-relaxed max-w-2xl mx-auto">
        Oikos werkt samen met enthousiaste woningeigenaren aan een duurzame toekomst.
        Neem contact op voor een vrijblijvend gesprek.
      </p>
      <a href="/#contact" class="bg-white text-oikos-green hover:bg-gray-100 px-10 py-4 rounded-full font-bold text-base transition-colors inline-block shadow-lg">
        {{ instellingen.knop_contact }}
      </a>
    </div>
  </section>
  {% endif %}

  <!-- ===== FOOTER ===== -->
  <footer id="contact" class="bg-oikos-dark text-white py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-16">

        <div class="col-span-2 md:col-span-1">
          <img src="/assets/img/logo-hart-wit-groen.png" alt="Oikos Bouwend Bureau" class="h-14 w-auto mb-5 opacity-90" />
          <p class="text-gray-400 text-sm leading-relaxed">{{ instellingen.footer_tekst }}</p>
          <div class="mt-4">
            <a href="mailto:{{ instellingen.email_hoofd }}" class="text-gray-400 hover:text-oikos-green transition-colors text-sm">{{ instellingen.email_hoofd }}</a>
          </div>
        </div>

        <div>
          <h4 class="font-semibold text-white mb-5 tracking-wide text-xs uppercase">Guido Bouwman</h4>
          <ul class="space-y-3 text-gray-400 text-sm">
            <li>
              <a href="mailto:{{ instellingen.email_guido }}" class="hover:text-oikos-green transition-colors">{{ instellingen.email_guido }}</a>
            </li>
            <li>
              <a href="{{ instellingen.linkedin_guido }}" target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-oikos-green transition-colors">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
            </li>
          </ul>
        </div>

        <div>
          <h4 class="font-semibold text-white mb-5 tracking-wide text-xs uppercase">Thom</h4>
          <ul class="space-y-3 text-gray-400 text-sm">
            <li>
              <a href="mailto:{{ instellingen.email_thom }}" class="hover:text-oikos-green transition-colors">{{ instellingen.email_thom }}</a>
            </li>
            {% if instellingen.linkedin_thom %}
            <li>
              <a href="{{ instellingen.linkedin_thom }}" target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-oikos-green transition-colors">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
            </li>
            {% else %}
            <li class="text-gray-600 text-xs italic">LinkedIn volgt</li>
            {% endif %}
          </ul>
        </div>

        <div>
          <h4 class="font-semibold text-white mb-5 tracking-wide text-xs uppercase">Navigatie</h4>
          <ul class="space-y-2 text-gray-400 text-sm">
            <li><a href="/#over-ons"  class="hover:text-oikos-green transition-colors">Over Oikos</a></li>
            <li><a href="/materialen/" class="hover:text-oikos-green transition-colors">Materialen</a></li>
            <li><a href="/#projecten" class="hover:text-oikos-green transition-colors">Projecten</a></li>
            <li><a href="/#contact"   class="hover:text-oikos-green transition-colors">Contact</a></li>
          </ul>
        </div>

      </div>
      <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-3 text-gray-500 text-xs">
        <p>© 2025 Oikos, Bouwend Bureau. Alle rechten voorbehouden.</p>
        <span class="flex items-center gap-2">
          <span class="text-gray-600">Website gebouwd door</span>
          <a href="https://flow-company.nl" target="_blank" rel="noopener" class="text-oikos-green hover:text-white transition-colors font-semibold tracking-wide">flow-company.nl ↗</a>
        </span>
      </div>
    </div>
  </footer>

  <script>
    const mobileMenu = document.getElementById('mobile-menu');
    document.getElementById('mobile-menu-btn').addEventListener('click', function() {
      mobileMenu.classList.toggle('hidden');
    });
    // Sluit menu zodra een link aangeklikt wordt
    mobileMenu.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', function() {
        mobileMenu.classList.add('hidden');
      });
    });
    // Sluit menu bij scrollen
    window.addEventListener('scroll', function() {
      mobileMenu.classList.add('hidden');
    }, { passive: true });

    // Nav: transparant op hero, wit als je scrollt
    const nav = document.getElementById('main-nav');
    const logoLight = document.getElementById('logo-light');
    const logoDark  = document.getElementById('logo-dark');
    const navLinks  = document.querySelectorAll('.nav-link');
    const menuBtn   = document.getElementById('mobile-menu-btn');
    const isHome    = document.querySelector('#home') !== null;

    function setNavState(onHero) {
      if (onHero) {
        nav.style.background = 'transparent';
        nav.style.backdropFilter = 'none';
        logoLight.style.opacity = '1';
        logoDark.style.opacity  = '0';
        navLinks.forEach(l => l.style.color = 'rgba(255,255,255,0.90)');
        menuBtn.style.color = 'white';
      } else {
        nav.style.background = 'rgba(255,255,255,0.96)';
        nav.style.backdropFilter = 'blur(8px)';
        logoLight.style.opacity = '0';
        logoDark.style.opacity  = '1';
        navLinks.forEach(l => l.style.color = '#1a1a1a');
        menuBtn.style.color = '#3C3C3C';
      }
    }

    const sections = document.querySelectorAll('[data-nav-bg]');
    if (sections.length > 0) {
      // Volg welke sectie bovenaan staat
      const sectionObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const bg    = entry.target.dataset.navBg;
            const theme = entry.target.dataset.navTheme;
            const onLight = (theme === 'dark');
            nav.style.background = bg === 'transparent' ? 'transparent' : bg;
            nav.style.backdropFilter = bg === 'transparent' ? 'none' : 'blur(8px)';
            logoLight.style.opacity = onLight ? '0' : '1';
            logoDark.style.opacity  = onLight ? '1' : '0';
            navLinks.forEach(l => l.style.color = onLight ? '#1a1a1a' : 'rgba(255,255,255,0.90)');
            menuBtn.style.color = onLight ? '#3C3C3C' : 'white';
          }
        });
      }, { threshold: 0, rootMargin: '-50px 0px -80% 0px' });
      sections.forEach(s => sectionObserver.observe(s));
    } else {
      // Niet-homepage: altijd wit
      setNavState(false);
    }

    // Scroll-driven animations
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('in-view'); io.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('.fade-up, .fade-right, .line-draw').forEach(el => io.observe(el));

    // Count-up for stats
    function countUp(el) {
      const target = +el.dataset.count;
      const suffix = el.dataset.suffix || '';
      const dur = 1400;
      const t0 = performance.now();
      (function step(now) {
        const p = Math.min((now - t0) / dur, 1);
        const v = Math.round((1 - Math.pow(1 - p, 3)) * target);
        el.textContent = v + suffix;
        if (p < 1) requestAnimationFrame(step);
      })(t0);
    }
    const cntObs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) { countUp(e.target); cntObs.unobserve(e.target); } });
    }, { threshold: 0.7 });
    document.querySelectorAll('[data-count]').forEach(el => cntObs.observe(el));
  </script>
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }

    // Typewriter effect
    const tw = document.getElementById('hero-typewriter');
    if (tw) {
      const phrases = {{ instellingen.typewriter_zinnen | dump | safe }};
      let pi = 0, ci = 0, deleting = false;
      function type() {
        const phrase = phrases[pi];
        if (!deleting) {
          tw.textContent = phrase.slice(0, ci + 1);
          ci++;
          if (ci === phrase.length) { deleting = true; setTimeout(type, 2200); return; }
          setTimeout(type, 55);
        } else {
          tw.textContent = phrase.slice(0, ci - 1);
          ci--;
          if (ci === 0) { deleting = false; pi = (pi + 1) % phrases.length; setTimeout(type, 400); return; }
          setTimeout(type, 28);
        }
      }
      setTimeout(type, 800);
    }

    // Hero slideshow
    const slides = document.querySelectorAll('.hero-slide');
    if (slides.length > 1) {
      let current = 0;
      setInterval(() => {
        slides[current].classList.remove('active');
        current = (current + 1) % slides.length;
        slides[current].classList.add('active');
      }, 5000);
    }
  </script>
</body>
</html>
