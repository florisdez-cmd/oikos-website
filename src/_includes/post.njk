---
layout: base.njk
---
<main class="pt-24 pb-20 bg-white">
  <div class="max-w-3xl mx-auto px-6">

    <a href="/#projecten" class="inline-flex items-center gap-1.5 text-oikos-green hover:text-oikos-green-dark text-sm font-semibold mb-10 transition-colors leading-none">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 translate-y-px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <span>Terug naar projecten & nieuws</span>
    </a>

    <p class="text-oikos-green text-xs font-bold tracking-widest uppercase mb-4">
      {{ category or "Nieuws" }} · {{ page.date | dutchDateFull }}
    </p>

    <h1 class="text-3xl md:text-4xl font-extrabold text-oikos-dark leading-tight mb-8">{{ title }}</h1>

    {% if image %}
    <div class="rounded-2xl overflow-hidden mb-10 aspect-video">
      <img src="{{ image }}" alt="{{ title }}" class="w-full h-full object-cover" />
    </div>
    {% endif %}

    <div class="text-oikos-gray leading-relaxed text-lg space-y-5
                [&_h2]:text-oikos-dark [&_h2]:font-bold [&_h2]:text-2xl [&_h2]:mt-10 [&_h2]:mb-4
                [&_h3]:text-oikos-dark [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-3
                [&_a]:text-oikos-green [&_a]:underline
                [&_strong]:text-oikos-dark
                [&_ul]:list-disc [&_ul]:pl-6 [&_li]:mb-1">
      {{ content | safe }}
    </div>

  </div>
</main>
